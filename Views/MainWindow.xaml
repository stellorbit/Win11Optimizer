<Window x:Class="Win11Optimizer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Win11Optimizer.Converters"
        mc:Ignorable="d"
        Title="Win11Optimizer Core"
        Height="820" Width="1000" MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#FF1A1A2E"
        Foreground="White">

    <Window.Resources>
        <!-- Converters -->
        <local:BoolToArrowConverter x:Key="BoolToArrowConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:RestartToVisibilityConverter x:Key="RestartToVisibilityConverter"/>
        <local:RestartToTextConverter x:Key="RestartToTextConverter"/>
        
        <!-- カラーパレット -->
        <SolidColorBrush x:Key="BgDark"       Color="#FF1A1A2E"/>
        <SolidColorBrush x:Key="BgMid"        Color="#FF16213E"/>
        <SolidColorBrush x:Key="BgLight"      Color="#FF0F3460"/>
        <SolidColorBrush x:Key="Accent"       Color="#FFE94560"/>
        <SolidColorBrush x:Key="AccentLight"  Color="#FFFF6B6B"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FFAAAACC"/>
        <SolidColorBrush x:Key="ToggleOn"     Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="ToggleOff"    Color="#FF607D8B"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#FF2A2A4A"/>

        <!-- ToggleButton スタイル (スライダー風) -->
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    CornerRadius="12" Background="{StaticResource ToggleOff}"
                                    Width="48" Height="24"/>
                            <Ellipse x:Name="Thumb"
                                     Width="18" Height="18"
                                     Fill="White"
                                     HorizontalAlignment="Left"
                                     Margin="3,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource ToggleOn}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="24" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- カテゴリヘッダーボタン -->
        <Style x:Key="CategoryHeaderStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource BgLight}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1A4060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 汎用ボタンスタイル -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentLight}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BgLight}"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFC0392B"/>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- スクロールバー -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- タイトルバー -->
            <RowDefinition Height="Auto"/>  <!-- ツールバー -->
            <RowDefinition Height="*"/>     <!-- メインコンテンツ -->
            <RowDefinition Height="Auto"/>  <!-- ステータス -->
        </Grid.RowDefinitions>

        <!-- ===== タイトルバー ===== -->
        <Border Grid.Row="0" Background="{StaticResource BgMid}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚙" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource Accent}"/>
                    <TextBlock Text="Win11Optimizer" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  Privacy / Cloud Off Core" FontSize="12"
                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="AdminBadge"
                               Text="🔑 管理者権限" FontSize="11"
                               Foreground="#FF4CAF50" VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== ツールバー ===== -->
        <Border Grid.Row="1" Background="{StaticResource BgMid}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左側ボタン群 -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnMenu" Content="☰"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="BtnMenu_Click" Margin="0,0,8,0">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="MainMenu">
                                <MenuItem Header="復元ポイントの作成" Click="MenuCreateRestorePoint_Click"/>
                                <Separator/>
                                <MenuItem Header="バージョン情報" Click="MenuAbout_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="BtnApply" Content="✅ 選択した項目の設定を適用"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="BtnApply_Click" Margin="0,0,8,0"/>                    <Button x:Name="BtnExport" Content="💾 JSONで設定を保存"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BtnExport_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnImport" Content="📂 JSONを開く"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BtnImport_Click" Margin="0,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnRollback" Content="⟲ 初期設定ロールバック"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="BtnRollback_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== メインコンテンツ ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>   <!-- カテゴリナビ -->
                <ColumnDefinition Width="*"/>      <!-- ツイークリスト -->
            </Grid.ColumnDefinitions>

            <!-- カテゴリ一覧 -->
            <Border Background="{StaticResource BgMid}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                <ListBox x:Name="CategoryNav"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="CategoryNav_SelectionChanged"
                         Margin="8">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgLight}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>

            <!-- ツイークリスト（スクロール可能） -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <ItemsControl x:Name="TweakList" Margin="16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- カテゴリグループ -->
                            <Border Margin="0,0,0,12" CornerRadius="8"
                                    Background="{StaticResource BgMid}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <!-- カテゴリヘッダー (折り畳み) -->
                                    <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                  Style="{StaticResource CategoryHeaderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding IsExpanded, Converter={StaticResource BoolToArrowConverter}}"
                                                       Foreground="{StaticResource TextSecondary}"/>
                                        </Grid>
                                    </ToggleButton>

                                    <!-- ツイーク一覧 -->
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="12,8" Margin="0,0,0,1"
                                                        Background="Transparent">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#0AFFFFFF"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 名前・説明 -->
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="13" FontWeight="Medium"
                                                                       Foreground="{StaticResource TextPrimary}"/>
                                                            <TextBlock Text="{Binding Description}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                            <!-- 再起動ラベル -->
                                                            <TextBlock Margin="0,2,0,0" FontSize="10"
                                                                       Visibility="{Binding RestartRequirement, Converter={StaticResource RestartToVisibilityConverter}}"
                                                                       Text="{Binding RestartRequirement, Converter={StaticResource RestartToTextConverter}}"
                                                                       Foreground="#FFFFA500"/>
                                                        </StackPanel>

                                                        <!-- ローディングスピナー -->
                                                        <ProgressBar Grid.Column="1"
                                                                     Width="20" Height="20" Margin="8,0"
                                                                     IsIndeterminate="True"
                                                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                        <!-- トグルスイッチ (ファイルピッカー項目は非表示) -->
                                                        <ToggleButton Grid.Column="2"
                                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                      IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                                                      VerticalAlignment="Center">
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton" BasedOn="{StaticResource ToggleSwitchStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFilePickerItem}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>
                                                        <!-- ファイルピッカー項目の UI (参照ボタン + パス表示) -->
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFilePickerItem}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="{Binding SelectedPath}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       VerticalAlignment="Center"
                                                                       MaxWidth="180"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,0,6,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasSelectedPath}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <Button Content="📂 参照..."
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="10,4"
                                                                    FontSize="11"
                                                                    Tag="{Binding}"
                                                                    Click="BtnFilePicker_Click"
                                                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ===== ステータスバー ===== -->
        <Border Grid.Row="3" Background="{StaticResource BgMid}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="準備完了"
                           FontSize="11" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="VersionText" Text="Version 2024.04"
                           FontSize="10" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ===== 進捗ポップアップ ===== -->
        <Border x:Name="ProgressPopup"
                Grid.RowSpan="4"
                Width="320"
                Padding="14,12"
                Margin="16,0,0,42"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                Background="{StaticResource BgMid}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock x:Name="ProgressLabel" Text="処理中..." FontSize="11"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                <Border CornerRadius="3" Background="{StaticResource BgLight}" Height="6" ClipToBounds="True">
                    <ProgressBar x:Name="MainProgressBar" Height="6" Background="Transparent"
                                 Foreground="{StaticResource Accent}" BorderThickness="0"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>


