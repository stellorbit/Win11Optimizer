<Window x:Class="Win11Optimizer.Views.RestoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定の復元" Height="420" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1A1A2E"
        Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="復元するバックアップを選択してください"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="White" Margin="0,0,0,12"/>

        <ListBox Grid.Row="1" x:Name="BackupList"
                 Background="#FF16213E" Foreground="White"
                 BorderBrush="#FF2A2A4A" BorderThickness="1"
                 Margin="0,0,0,12">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="10,6"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FF0F3460"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <TextBlock Grid.Row="2" x:Name="BackupInfo"
                   Foreground="#FFAAAACC" FontSize="11"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnRestore" Content="復元を実行"
                    Width="120" Height="32" Margin="0,0,8,0"
                    Background="#FFE94560" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    IsEnabled="False"
                    Click="BtnRestore_Click"/>
            <Button Content="キャンセル"
                    Width="80" Height="32"
                    Background="#FF0F3460" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
